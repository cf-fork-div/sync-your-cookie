# Cloudflare API Token (Workers KV Storage:Edit + Workers Scripts:Edit)
# Or run `wrangler login` once instead of setting this.
CLOUDFLARE_API_TOKEN=

# Optional: skip auto-detection
CLOUDFLARE_ACCOUNT_ID=

# --- Runtime Web Viewer settings (Cloudflare Worker, no rebuild needed) ---
# Set in Cloudflare Dashboard → Workers & Pages → sync-your-cookie → Settings → Variables and Secrets
# Or let deploy.mjs push them on first deploy (see DEPLOY_RUNTIME_SECRETS below).

# Encrypted secret — login password (NOT baked into JS)
WEB_ACCESS_PASSWORD=change-me-to-a-strong-password

# Plain env var — optional custom URL path segment (omit to serve at /)
# WEB_BASE_PATH=my-cookie-vault

# Optional: Git CI — bind existing KV without auto-create (also set in Dashboard Variables)
# SYNC_KV_NAMESPACE_ID=

# Set to 1 to push WEB_ACCESS_PASSWORD via wrangler on deploy (optional)
# DEPLOY_RUNTIME_SECRETS=1

# --- Local dev only (pnpm dev:web) — ignored by Cloudflare deploy build ---
# VITE_WEB_ACCESS_PASSWORD=dev
# VITE_WEB_BASE_PATH=my-cookie-vault
