{
  "name": "@sync-your-cookie/web",
  "version": "0.0.1",
  "description": "web viewer for synced cookies",
  "private": true,
  "sideEffects": true,
  "files": [
    "dist/**"
  ],
  "scripts": {
    "clean": "rimraf ./dist && rimraf .turbo",
    "build": "pnpm run clean && tsc --noEmit && vite build",
    "build:watch": "cross-env __DEV__=true vite build -w --mode development",
    "dev": "vite",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "pnpm lint --fix",
    "prettier": "prettier . --write",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@sync-your-cookie/protobuf": "workspace:*",
    "@sync-your-cookie/shared": "workspace:*",
    "clsx": "^2.1.1",
    "lucide-react": "^0.394.0",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@sync-your-cookie/tailwindcss-config": "workspace:*",
    "@sync-your-cookie/tsconfig": "workspace:*",
    "@sync-your-cookie/ui": "workspace:*",
    "@vitejs/plugin-react-swc": "^3.6.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "5.2.2",
    "typescript-transform-paths": "^3.4.10",
    "vite": "^5.2.11"
  }
}
